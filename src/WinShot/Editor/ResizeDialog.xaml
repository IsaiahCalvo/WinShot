<Window x:Class="WinShot.Editor.ResizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize image" Background="#2B2B2B"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="76"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18,16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (px)" Foreground="#BBFFFFFF"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,10,8"/>
            <TextBox x:Name="WidthBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource Field}"
                     Margin="0,0,0,8" TextChanged="OnWidthChanged"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Height (px)" Foreground="#BBFFFFFF"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,10,8"/>
            <TextBox x:Name="HeightBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource Field}"
                     Margin="0,0,0,8" TextChanged="OnHeightChanged"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Scale (%)" Foreground="#BBFFFFFF"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="PercentBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource Field}"
                     TextChanged="OnPercentChanged"/>
            <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource ActionButton}" Content="50%" Tag="50" Click="OnQuickPercent"/>
                <Button Style="{StaticResource ActionButton}" Content="200%" Tag="200" Click="OnQuickPercent"/>
            </StackPanel>
        </Grid>

        <CheckBox x:Name="LockRatio" Content="Lock aspect ratio" IsChecked="True"
                  Foreground="White" FontSize="12" Margin="0,8,0,0"/>

        <TextBlock x:Name="InfoText" Foreground="#88FFFFFF" FontSize="11" Margin="0,8,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource AccentButton}" Content="Resize" Click="OnOk" IsDefault="True"/>
            <Button Style="{StaticResource ActionButton}" Content="Cancel" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
