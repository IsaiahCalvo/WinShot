<Window x:Class="WinShot.Editor.Background.BackgroundComposerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot — Background" Background="#2B2B2B"
        Width="1060" Height="680" MinWidth="880" MinHeight="540"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#2D7DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4DA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AspectButton" TargetType="RadioButton">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Aspect"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetSwatch" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Ring" CornerRadius="8" BorderBrush="#33FFFFFF"
                                BorderThickness="2" Padding="1">
                            <Border Width="38" Height="26" CornerRadius="5"
                                    Background="{TemplateBinding Background}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="BorderBrush" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SolidSwatch" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="24" Height="24" Background="Transparent">
                            <Ellipse x:Name="Ring" Stroke="Transparent" StrokeThickness="2"/>
                            <Ellipse Width="14" Height="14" Fill="{TemplateBinding Background}"
                                     Stroke="#66FFFFFF" StrokeThickness="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4DA3FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BBFFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2D7DFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" Height="22">
                            <Border Height="4" CornerRadius="2" Background="#4A4A4A" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Grid Background="Transparent">
                                                    <Border Height="4" CornerRadius="2" Background="#2D7DFF"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Focusable="False" Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Stroke="#2D7DFF" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Right control panel -->
        <Border DockPanel.Dock="Right" Width="280" Background="#242424"
                BorderBrush="#1AFFFFFF" BorderThickness="1,0,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Bottom" Padding="14,10"
                        BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnCopy" Style="{StaticResource ActionButton}"
                                    Content="Copy" MinWidth="64" Click="OnCopy"/>
                            <Button x:Name="BtnSave" Style="{StaticResource AccentButton}"
                                    Content="Save…" MinWidth="64" Click="OnSave"/>
                        </StackPanel>
                        <TextBlock x:Name="SizeLabel" Style="{StaticResource ValueLabel}"
                                   ToolTip="Output size in pixels"/>
                    </DockPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,4,14,16">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Layout"/>
                        <DockPanel>
                            <TextBlock x:Name="PadValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Padding"/>
                        </DockPanel>
                        <Slider x:Name="PaddingSlider" Style="{StaticResource DarkSlider}"
                                Minimum="0" Maximum="200" Value="64"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,8"/>
                        <DockPanel>
                            <TextBlock x:Name="RadiusValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Corner radius"/>
                        </DockPanel>
                        <Slider x:Name="RadiusSlider" Style="{StaticResource DarkSlider}"
                                Minimum="0" Maximum="32" Value="12"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,8"/>
                        <CheckBox x:Name="ShadowCheck" Content="Drop shadow" IsChecked="True"
                                  Checked="OnShadowToggled" Unchecked="OnShadowToggled" Margin="0,4,0,2"/>
                        <DockPanel Margin="0,6,0,0"
                                   IsEnabled="{Binding IsChecked, ElementName=ShadowCheck}">
                            <TextBlock x:Name="BlurValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Shadow blur"/>
                        </DockPanel>
                        <Slider x:Name="BlurSlider" Style="{StaticResource DarkSlider}"
                                Minimum="4" Maximum="100" Value="32"
                                IsEnabled="{Binding IsChecked, ElementName=ShadowCheck}"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,0"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Canvas"/>
                        <WrapPanel>
                            <RadioButton Style="{StaticResource AspectButton}" Tag="auto" Content="Auto"
                                         IsChecked="True" Checked="OnAspectChecked"
                                         ToolTip="Canvas hugs the image plus padding"/>
                            <RadioButton Style="{StaticResource AspectButton}" Tag="1:1" Content="1:1" Checked="OnAspectChecked"/>
                            <RadioButton Style="{StaticResource AspectButton}" Tag="4:3" Content="4:3" Checked="OnAspectChecked"/>
                            <RadioButton Style="{StaticResource AspectButton}" Tag="16:9" Content="16:9" Checked="OnAspectChecked"/>
                            <RadioButton Style="{StaticResource AspectButton}" Tag="9:16" Content="9:16" Checked="OnAspectChecked"/>
                        </WrapPanel>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Background"/>
                        <WrapPanel x:Name="PresetPanel"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Solid color" Margin="0,8,0,4"/>
                        <DockPanel>
                            <TextBox x:Name="HexBox" Width="84" DockPanel.Dock="Right"
                                     TextChanged="OnHexChanged"
                                     ToolTip="Hex color, e.g. #1E1E2E (or a WPF color name)"/>
                            <WrapPanel x:Name="SolidPanel" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Image" Margin="0,12,0,4"/>
                        <DockPanel>
                            <Button Style="{StaticResource ActionButton}" Content="Browse…"
                                    Margin="0" Click="OnBrowseImage"/>
                            <TextBlock x:Name="ImageNameText" Style="{StaticResource ValueLabel}"
                                       Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Live preview. ComposeRoot keeps a 1 DIP = 1 source pixel layout; the
             Viewbox only scales the view, and its scale lives on an ancestor
             visual so the flatten (RenderVisual of ComposeRoot) is unaffected. -->
        <Grid Background="#1E1E1E">
            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="24">
                <Grid x:Name="ComposeRoot">
                    <Border x:Name="ShotBorder" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Viewbox>
        </Grid>
    </DockPanel>
</Window>
