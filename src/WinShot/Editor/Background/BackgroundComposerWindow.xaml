<Window x:Class="WinShot.Editor.Background.BackgroundComposerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot - Background" Background="{StaticResource WindowBgBrush}"
        Width="1060" Height="680" MinWidth="880" MinHeight="540"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True">

    <DockPanel>
        <!-- Left control panel -->
        <Border DockPanel.Dock="Left" Width="280" Style="{StaticResource PanelSurface}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Bottom commit bar -->
                <Border DockPanel.Dock="Bottom" Padding="14,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnCopy" Style="{StaticResource PillButtonSecondary}"
                                    Content="Copy" Click="OnCopy"/>
                            <Button x:Name="BtnSave" Style="{StaticResource PillButtonPrimary}"
                                    Content="Save as..." Click="OnSave"/>
                        </StackPanel>
                        <TextBlock x:Name="SizeLabel" Style="{StaticResource ValueLabel}"
                                   ToolTip="Output size in pixels"/>
                    </DockPanel>
                </Border>

                <ScrollViewer x:Name="ComposerControls" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="14,12,14,16">
                        <!-- Current preset name header -->
                        <TextBlock x:Name="PresetNameHeader" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,4" Text="None"/>

                        <!-- ============ BACKGROUND SECTIONS ============ -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Gradients"/>
                        <WrapPanel x:Name="PresetPanel"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Wallpapers"/>
                        <WrapPanel x:Name="WallpaperPanel"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Blurred"/>
                        <WrapPanel x:Name="BlurredPanel"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Plain color"/>
                        <WrapPanel x:Name="SolidPanel" Margin="0,0,0,6"/>
                        <TextBox x:Name="HexBox" Style="{StaticResource DarkTextBox}"
                                 TextChanged="OnHexChanged"
                                 ToolTip="Hex color, e.g. #1E1E2E (or a WPF color name)"/>

                        <!-- ============ LAYOUT SLIDERS ============ -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Layout"/>

                        <DockPanel>
                            <TextBlock x:Name="PadValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Padding"/>
                        </DockPanel>
                        <Slider x:Name="PaddingSlider" Style="{StaticResource DarkSlider}"
                                Minimum="0" Maximum="200" Value="64"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,8"/>

                        <DockPanel>
                            <TextBlock x:Name="InsetValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Inset"/>
                        </DockPanel>
                        <Slider x:Name="InsetSlider" Style="{StaticResource DarkSlider}"
                                Minimum="0" Maximum="120" Value="0"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,4"/>
                        <CheckBox x:Name="AutoBalanceCheck" Style="{StaticResource DarkCheckBox}"
                                  Content="Auto-balance" Margin="0,0,0,8"
                                  Checked="OnAutoBalanceToggled" Unchecked="OnAutoBalanceToggled"/>

                        <CheckBox x:Name="ShadowCheck" Style="{StaticResource DarkCheckBox}"
                                  Content="Drop shadow" IsChecked="True"
                                  Checked="OnShadowToggled" Unchecked="OnShadowToggled" Margin="0,4,0,2"/>
                        <DockPanel Margin="0,6,0,0"
                                   IsEnabled="{Binding IsChecked, ElementName=ShadowCheck}">
                            <TextBlock x:Name="BlurValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Shadow"/>
                        </DockPanel>
                        <Slider x:Name="BlurSlider" Style="{StaticResource DarkSlider}"
                                Minimum="4" Maximum="100" Value="32"
                                IsEnabled="{Binding IsChecked, ElementName=ShadowCheck}"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,8"/>

                        <DockPanel>
                            <TextBlock x:Name="RadiusValueLabel" DockPanel.Dock="Right"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Corners"/>
                        </DockPanel>
                        <Slider x:Name="RadiusSlider" Style="{StaticResource DarkSlider}"
                                Minimum="0" Maximum="32" Value="12"
                                ValueChanged="OnSliderChanged" Margin="0,2,0,8"/>

                        <!-- ============ ALIGNMENT ============ -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Alignment"/>
                        <!-- ToggleButton has no GroupName; mutual exclusivity is
                             enforced in OnAlignChecked (un-checks the siblings). -->
                        <UniformGrid Rows="3" Columns="3" HorizontalAlignment="Left" Width="126">
                            <ToggleButton x:Name="AlignTL" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="TL"
                                          Checked="OnAlignChecked" ToolTip="Top left"/>
                            <ToggleButton x:Name="AlignTC" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="TC"
                                          Checked="OnAlignChecked" ToolTip="Top center"/>
                            <ToggleButton x:Name="AlignTR" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="TR"
                                          Checked="OnAlignChecked" ToolTip="Top right"/>
                            <ToggleButton x:Name="AlignCL" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="CL"
                                          Checked="OnAlignChecked" ToolTip="Center left"/>
                            <ToggleButton x:Name="AlignCC" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="CC"
                                          IsChecked="True" Checked="OnAlignChecked" ToolTip="Center"/>
                            <ToggleButton x:Name="AlignCR" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="CR"
                                          Checked="OnAlignChecked" ToolTip="Center right"/>
                            <ToggleButton x:Name="AlignBL" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="BL"
                                          Checked="OnAlignChecked" ToolTip="Bottom left"/>
                            <ToggleButton x:Name="AlignBC" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="BC"
                                          Checked="OnAlignChecked" ToolTip="Bottom center"/>
                            <ToggleButton x:Name="AlignBR" Style="{StaticResource ToolButton}"
                                          Content="&#xE91F;" Tag="BR"
                                          Checked="OnAlignChecked" ToolTip="Bottom right"/>
                        </UniformGrid>

                        <!-- ============ RATIO ============ -->
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Ratio"/>
                        <ComboBox x:Name="RatioBox" Style="{StaticResource DarkComboBox}"
                                  SelectedIndex="0" SelectionChanged="OnRatioChanged">
                            <ComboBoxItem Content="Auto" Tag="auto"/>
                            <ComboBoxItem Content="16:9" Tag="16:9"/>
                            <ComboBoxItem Content="4:3" Tag="4:3"/>
                            <ComboBoxItem Content="1:1" Tag="1:1"/>
                            <ComboBoxItem Content="9:16" Tag="9:16"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Live preview. ComposeRoot keeps a 1 DIP = 1 source pixel layout; the
             Viewbox only scales the view, and its scale lives on an ancestor
             visual so the flatten (RenderVisual of ComposeRoot) is unaffected. -->
        <Grid Background="{StaticResource WindowBgBrush}">
            <Viewbox x:Name="PreviewBox" Stretch="Uniform" StretchDirection="DownOnly" Margin="24"
                     Visibility="Collapsed">
                <Grid x:Name="ComposeRoot">
                    <Border x:Name="ShotBorder" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Viewbox>
        </Grid>
    </DockPanel>
</Window>
