<Window x:Class="WinShot.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot Editor" Background="#2B2B2B"
        MinWidth="980" MinHeight="460"
        AllowDrop="True" Drop="OnEditorDrop" DragOver="OnEditorDragOver"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#2D7DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4DA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="RadioButton">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Tool"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SizeButton" TargetType="RadioButton" BasedOn="{StaticResource ToolButton}">
            <Setter Property="GroupName" Value="Stroke"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinWidth" Value="30"/>
        </Style>

        <Style x:Key="FillButton" TargetType="RadioButton" BasedOn="{StaticResource ToolButton}">
            <Setter Property="GroupName" Value="Fill"/>
            <Setter Property="MinWidth" Value="34"/>
        </Style>

        <Style x:Key="Swatch" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Color"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="24" Height="24" Background="Transparent">
                            <Ellipse x:Name="Ring" Stroke="Transparent" StrokeThickness="2"/>
                            <Ellipse Width="14" Height="14" Fill="{TemplateBinding Background}"
                                     Stroke="#66FFFFFF" StrokeThickness="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmojiButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                          Background="#3A3A3A"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,4,24,4" VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Path Data="M0,0 L4,4 8,0" Stroke="#BBFFFFFF" StrokeThickness="1.5"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,1,9,0" IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Background="#2B2B2B" BorderBrush="#33FFFFFF" BorderThickness="1"
                                        CornerRadius="6" Padding="4" Margin="0,3,12,12"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#242424" Padding="10,8"
                BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnCopy" Style="{StaticResource ActionButton}" Content="Copy" Click="OnCopy"/>
                        <Button x:Name="BtnSave" Style="{StaticResource ActionButton}" Content="Save…" Click="OnSave"/>
                        <Button Style="{StaticResource ActionButton}" Content="Close" Click="OnClose"/>
                    </StackPanel>
                    <WrapPanel x:Name="ToolPanel" VerticalAlignment="Center">
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Select" Content="↖" MinWidth="30"
                                     ToolTip="Select — click an annotation to select, drag to move, Del deletes, double-click text to edit"
                                     Checked="OnToolChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Pan" Content="✋" MinWidth="30"
                                     ToolTip="Pan — drag to move the view (middle-drag or hold Space works with any tool)"
                                     Checked="OnToolChecked"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,3"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Arrow" Content="Arrow" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="CurvedArrow" Content="Curve"
                                     ToolTip="Curved arrow — drag start to end, then drag the blue handle to bend it"
                                     Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Line" Content="Line" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Rectangle" Content="Rect" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Ellipse" Content="Ellipse" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Freehand" Content="Draw" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Highlighter" Content="Highlight" Checked="OnToolChecked"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,3"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Text" Content="Text" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Step" Content="Step" Checked="OnToolChecked"/>
                        <RadioButton x:Name="EmojiToolBtn" Style="{StaticResource ToolButton}" Tag="Emoji" Content="😀" MinWidth="32"
                                     ToolTip="Emoji — pick an emoji, then click the image to place it"
                                     Checked="OnToolChecked" Click="OnEmojiButtonClick"/>
                        <Popup x:Name="EmojiPopup" PlacementTarget="{Binding ElementName=EmojiToolBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="#2B2B2B" BorderBrush="#33FFFFFF" BorderThickness="1"
                                    CornerRadius="8" Padding="6" Margin="0,4,12,12">
                                <UniformGrid Columns="6">
                                    <Button Style="{StaticResource EmojiButton}" Content="😀" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😅" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😂" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😍" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🤔" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😎" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😢" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😡" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👍" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👎" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👏" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🙏" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👀" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="💪" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❤️" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🔥" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="⭐" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🎉" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="✅" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❌" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="⚠️" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❗" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="💡" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🚀" Click="OnEmojiPicked"/>
                                </UniformGrid>
                            </Border>
                        </Popup>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,3"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Blur" Content="Blur" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Pixelate" Content="Pixelate"
                                     ToolTip="Pixelate — irreversible randomized mosaic for sensitive text"
                                     Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Spotlight" Content="Spotlight"
                                     ToolTip="Spotlight — dim everything except the dragged region"
                                     Checked="OnToolChecked"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,3"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Crop" Content="Crop" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" Tag="Eyedropper" Content="💧" MinWidth="32"
                                     ToolTip="Eyedropper — click the image to pick that pixel's color"
                                     Checked="OnToolChecked"/>
                    </WrapPanel>
                </DockPanel>
                <DockPanel Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel x:Name="CropPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource AccentButton}" Content="Apply crop" Click="OnApplyCrop"/>
                            <Button Style="{StaticResource ActionButton}" Content="Cancel" Click="OnCancelCrop"/>
                            <Rectangle Width="1" Fill="#33FFFFFF" Margin="8,3"/>
                        </StackPanel>
                        <Button Style="{StaticResource ActionButton}" Content="⟲" MinWidth="30"
                                ToolTip="Rotate 90° counter-clockwise" Click="OnRotateCcw"/>
                        <Button Style="{StaticResource ActionButton}" Content="⟳" MinWidth="30"
                                ToolTip="Rotate 90° clockwise" Click="OnRotateCw"/>
                        <Button Style="{StaticResource ActionButton}" Content="⬌" MinWidth="30"
                                ToolTip="Flip horizontal" Click="OnFlipHorizontal"/>
                        <Button Style="{StaticResource ActionButton}" Content="⬍" MinWidth="30"
                                ToolTip="Flip vertical" Click="OnFlipVertical"/>
                        <Button Style="{StaticResource ActionButton}" Content="Resize…"
                                ToolTip="Resize the image" Click="OnResizeImage"/>
                        <Button Style="{StaticResource ActionButton}" Content="Add image…"
                                ToolTip="Insert an image file as a movable annotation (you can also drag and drop image files onto the editor)"
                                Click="OnAddImage"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="8,3"/>
                        <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="#BBFFFFFF" FontSize="12"
                                   MinWidth="42" TextAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,6,0" ToolTip="Zoom level (mouse wheel to zoom)"/>
                        <Button Style="{StaticResource ActionButton}" Content="Center" Click="OnCenterView"
                                ToolTip="Fit and center the image (Ctrl+0)"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="8,3"/>
                        <Button x:Name="BtnUndo" Style="{StaticResource ActionButton}" Content="↶ Undo" Click="OnUndo" IsEnabled="False"/>
                        <Button x:Name="BtnRedo" Style="{StaticResource ActionButton}" Content="↷ Redo" Click="OnRedo" IsEnabled="False"/>
                    </StackPanel>
                    <WrapPanel VerticalAlignment="Center">
                        <StackPanel x:Name="ColorPanel" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="CurrentColorIndicator" Width="16" Height="16" Fill="#FF3B30"
                                     Stroke="#88FFFFFF" StrokeThickness="1" Margin="2,0,8,0"
                                     VerticalAlignment="Center"
                                     ToolTip="Current color (pick a swatch or use the eyedropper)"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#FF3B30" ToolTip="Red" Checked="OnColorChecked" IsChecked="True"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#FF9500" ToolTip="Orange" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#FFCC00" ToolTip="Yellow" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#34C759" ToolTip="Green" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#2D7DFF" ToolTip="Blue" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#AF52DE" ToolTip="Purple" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#000000" ToolTip="Black" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource Swatch}" Background="#FFFFFF" ToolTip="White" Checked="OnColorChecked"/>
                        </StackPanel>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="10,3"/>
                        <RadioButton Style="{StaticResource SizeButton}" Tag="2" Content="2" ToolTip="Thin stroke" Checked="OnThicknessChecked"/>
                        <RadioButton Style="{StaticResource SizeButton}" Tag="4" Content="4" ToolTip="Medium stroke" Checked="OnThicknessChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource SizeButton}" Tag="6" Content="6" ToolTip="Thick stroke" Checked="OnThicknessChecked"/>
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="10,3"/>
                        <TextBlock Text="Fill" Foreground="#88FFFFFF" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <RadioButton Style="{StaticResource FillButton}" Tag="None" Content="None"
                                     ToolTip="New rectangles and ellipses have no fill" Checked="OnFillChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource FillButton}" Tag="Quarter" Content="25%"
                                     ToolTip="New rectangles and ellipses get a 25% fill" Checked="OnFillChecked"/>
                        <RadioButton Style="{StaticResource FillButton}" Tag="Solid" Content="Solid"
                                     ToolTip="New rectangles and ellipses get a solid fill" Checked="OnFillChecked"/>
                        <StackPanel x:Name="TextStylePanel" Orientation="Horizontal" Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <Rectangle Width="1" Fill="#33FFFFFF" Margin="10,3"/>
                            <TextBlock Text="Style" Foreground="#88FFFFFF" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="TextStyleBox" Style="{StaticResource DarkCombo}" Width="90"
                                      SelectedIndex="0" SelectionChanged="OnTextStyleChanged">
                                <ComboBoxItem Content="Plain" Tag="Plain"/>
                                <ComboBoxItem Content="Bold" Tag="Bold"/>
                                <ComboBoxItem Content="Outline" Tag="Outline"/>
                                <ComboBoxItem Content="Pill" Tag="Pill"/>
                                <ComboBoxItem Content="Huge" Tag="Huge"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="CropRatioPanel" Orientation="Horizontal" Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <Rectangle Width="1" Fill="#33FFFFFF" Margin="10,3"/>
                            <TextBlock Text="Ratio" Foreground="#88FFFFFF" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CropRatioBox" Style="{StaticResource DarkCombo}" Width="84"
                                      SelectedIndex="0" SelectionChanged="OnCropRatioChanged">
                                <ComboBoxItem Content="Free" Tag=""/>
                                <ComboBoxItem Content="1:1" Tag="1:1"/>
                                <ComboBoxItem Content="4:3" Tag="4:3"/>
                                <ComboBoxItem Content="16:9" Tag="16:9"/>
                                <ComboBoxItem Content="9:16" Tag="9:16"/>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Infinite canvas: the content keeps a 1 DIP = 1 source pixel layout and is
             positioned purely by the view transform below, so zoom/pan never touch
             annotation math or the flatten/export path (which renders CanvasHost only). -->
        <Grid x:Name="Viewport" Background="#1E1E1E" ClipToBounds="True"
              MouseWheel="OnViewportMouseWheel"
              MouseDown="OnViewportMouseDown"
              MouseMove="OnViewportMouseMove"
              MouseUp="OnViewportMouseUp">
            <Grid x:Name="EditorSurface" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Background="Transparent" Cursor="Cross" RenderTransformOrigin="0,0">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ViewScale"/>
                        <TranslateTransform x:Name="ViewTranslate"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid x:Name="CanvasHost">
                    <Image x:Name="BaseImage" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Canvas x:Name="AnnotationCanvas" Background="Transparent" ClipToBounds="True"/>
                </Grid>
                <Canvas x:Name="InteractionCanvas" IsHitTestVisible="False" ClipToBounds="True">
                    <Path x:Name="CropDim" Fill="#66000000" Visibility="Collapsed"/>
                    <Rectangle x:Name="DragRect" Stroke="#4DA3FF" StrokeThickness="1.5"
                               StrokeDashArray="4 3" Fill="#114DA3FF" Visibility="Collapsed"/>
                    <Rectangle x:Name="SelectionRect" Stroke="#4DA3FF" StrokeThickness="1.5"
                               StrokeDashArray="4 3" Visibility="Collapsed"/>
                    <Ellipse x:Name="CurveHandle" Width="10" Height="10" Fill="#4DA3FF"
                             Stroke="White" StrokeThickness="1.5" Visibility="Collapsed"/>
                    <Border x:Name="EyedropSwatch" Visibility="Collapsed" Background="#E61E1E1E"
                            CornerRadius="4" Padding="5" RenderTransformOrigin="0,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle x:Name="EyedropColorRect" Width="14" Height="14" RadiusX="2" RadiusY="2"
                                       Stroke="#88FFFFFF" StrokeThickness="1"/>
                            <TextBlock x:Name="EyedropHexText" Foreground="White" FontSize="11"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
