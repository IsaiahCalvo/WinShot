<Window x:Class="WinShot.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot Editor" Background="{StaticResource WindowBgBrush}"
        MinWidth="980" MinHeight="520"
        AllowDrop="True" Drop="OnEditorDrop" DragOver="OnEditorDragOver"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True">
    <Window.Resources>
        <!-- Emoji glyphs are color font content, not theme icon-font glyphs, so the
             emoji palette keeps a tiny local button style. Everything else comes
             from the shared Theme.xaml design system. -->
        <Style x:Key="EmojiButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverFillBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 3-row shell: floating toolbar over a full-bleed canvas over a floating
         bottom utility bar. Rows keep the canvas clear of both bars so the
         fit/center math (against Viewport size) is unaffected by the redesign. -->
    <Grid Background="{StaticResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== FLOATING TOP TOOLBAR ===================== -->
        <Border Grid.Row="0" Style="{StaticResource FloatingToolbar}" Margin="12,12,12,6">
            <StackPanel>
                <!-- Row 1: tools (left) + commit pills (right) -->
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnSave" Style="{StaticResource PillButtonSecondary}"
                                Content="Save as…" Click="OnSave" ToolTip="Save to a file…"/>
                        <Button Style="{StaticResource PillButtonPrimary}"
                                Content="Done" Click="OnClose" ToolTip="Finish and close the editor"/>
                    </StackPanel>
                    <WrapPanel x:Name="ToolPanel" VerticalAlignment="Center">
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Select" Content="&#xE8B0;"
                                     ToolTip="Select — click an annotation to select, drag to move, Del deletes, double-click text to edit"
                                     Checked="OnToolChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Pan" Content="&#xE7C2;"
                                     ToolTip="Pan — drag to move the view (middle-drag or hold Space works with any tool)"
                                     Checked="OnToolChecked"/>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Arrow" Content="&#xE72A;"
                                     ToolTip="Arrow" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="CurvedArrow" Content="&#xF0AD;"
                                     ToolTip="Curved arrow — drag start to end, then drag the blue handle to bend it"
                                     Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Line" Content="&#xE738;"
                                     ToolTip="Line" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Rectangle" Content="&#xE739;"
                                     ToolTip="Rectangle" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Ellipse" Content="&#xEA3A;"
                                     ToolTip="Ellipse" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Freehand" Content="&#xE70F;"
                                     ToolTip="Draw — freehand pen" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Highlighter" Content="&#xE891;"
                                     ToolTip="Highlighter" Checked="OnToolChecked"/>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Text" Content="&#xE8D2;"
                                     ToolTip="Text" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Step" Content="&#xE8EF;"
                                     ToolTip="Step counter — numbered badges" Checked="OnToolChecked"/>
                        <RadioButton x:Name="EmojiToolBtn" Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Emoji"
                                     FontFamily="Segoe UI Emoji" Content="😀"
                                     ToolTip="Emoji — pick an emoji, then click the image to place it"
                                     Checked="OnToolChecked" Click="OnEmojiButtonClick"/>
                        <Popup x:Name="EmojiPopup" PlacementTarget="{Binding ElementName=EmojiToolBtn}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource ElevatedBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource RadiusInput}" Padding="6" Margin="0,4,12,12"
                                    Effect="{StaticResource FloatingShadow}">
                                <UniformGrid Columns="6">
                                    <Button Style="{StaticResource EmojiButton}" Content="😀" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😅" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😂" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😍" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🤔" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😎" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😢" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="😡" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👍" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👎" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👏" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🙏" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="👀" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="💪" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❤️" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🔥" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="⭐" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🎉" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="✅" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❌" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="⚠️" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="❗" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="💡" Click="OnEmojiPicked"/>
                                    <Button Style="{StaticResource EmojiButton}" Content="🚀" Click="OnEmojiPicked"/>
                                </UniformGrid>
                            </Border>
                        </Popup>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Blur" Content="&#xE7E6;"
                                     ToolTip="Blur — smooth blur over a region" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Pixelate" Content="&#xE80A;"
                                     ToolTip="Pixelate — irreversible randomized mosaic for sensitive text"
                                     Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Spotlight" Content="&#xE8FB;"
                                     ToolTip="Spotlight — dim everything except the dragged region"
                                     Checked="OnToolChecked"/>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Crop" Content="&#xE7A8;"
                                     ToolTip="Crop" Checked="OnToolChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Tool" Tag="Eyedropper" Content="&#xEF3C;"
                                     ToolTip="Eyedropper — click the image to pick that pixel's color"
                                     Checked="OnToolChecked"/>
                    </WrapPanel>
                </DockPanel>

                <!-- Row 2: contextual style controls (left) + image utilities (right) -->
                <DockPanel Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel x:Name="CropPanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                            <Button Style="{StaticResource PillButtonPrimary}" Content="Apply crop" Click="OnApplyCrop"/>
                            <Button Style="{StaticResource PillButtonSecondary}" Content="Cancel" Click="OnCancelCrop"/>
                            <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        </StackPanel>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xE7AD;"
                                ToolTip="Rotate 90° counter-clockwise" Click="OnRotateCcw"/>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xE7AD;"
                                RenderTransformOrigin="0.5,0.5"
                                ToolTip="Rotate 90° clockwise" Click="OnRotateCw">
                            <Button.RenderTransform>
                                <ScaleTransform ScaleX="-1"/>
                            </Button.RenderTransform>
                        </Button>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xE13C;"
                                ToolTip="Flip horizontal" Click="OnFlipHorizontal"/>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xE174;"
                                ToolTip="Flip vertical" Click="OnFlipVertical"/>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xE740;"
                                ToolTip="Resize the image…" Click="OnResizeImage"/>
                        <Button Style="{StaticResource ToolIconButton}" Content="&#xEE71;"
                                ToolTip="Insert an image file as a movable annotation (you can also drag and drop image files onto the editor)"
                                Click="OnAddImage"/>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <Button x:Name="BtnUndo" Style="{StaticResource ToolIconButton}" Content="&#xE7A7;"
                                ToolTip="Undo" Click="OnUndo" IsEnabled="False"/>
                        <Button x:Name="BtnRedo" Style="{StaticResource ToolIconButton}" Content="&#xE7A6;"
                                ToolTip="Redo" Click="OnRedo" IsEnabled="False"/>
                    </StackPanel>
                    <WrapPanel VerticalAlignment="Center">
                        <StackPanel x:Name="ColorPanel" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="CurrentColorIndicator" Width="16" Height="16" Fill="{StaticResource AnnotationRedBrush}"
                                     Stroke="{StaticResource BorderStrongBrush}" StrokeThickness="1" Margin="2,0,8,0"
                                     VerticalAlignment="Center"
                                     ToolTip="Current color (pick a swatch or use the eyedropper)"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FF453A" ToolTip="Red" Checked="OnColorChecked" IsChecked="True"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FF9500" ToolTip="Orange" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FFCC00" ToolTip="Yellow" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#34C759" ToolTip="Green" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#0A84FF" ToolTip="Blue" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#AF52DE" ToolTip="Purple" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#000000" ToolTip="Black" Checked="OnColorChecked"/>
                            <RadioButton Style="{StaticResource ColorSwatch}" GroupName="Color" Background="#FFFFFF" ToolTip="White" Checked="OnColorChecked"/>
                        </StackPanel>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Stroke" Tag="2" Content="2" FontFamily="Segoe UI" FontSize="13" ToolTip="Thin stroke" Checked="OnThicknessChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Stroke" Tag="4" Content="4" FontFamily="Segoe UI" FontSize="13" ToolTip="Medium stroke" Checked="OnThicknessChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Stroke" Tag="6" Content="6" FontFamily="Segoe UI" FontSize="13" ToolTip="Thick stroke" Checked="OnThicknessChecked"/>
                        <Rectangle Style="{StaticResource ToolbarDivider}"/>
                        <TextBlock Text="Fill" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Fill" Tag="None" Content="&#xE739;"
                                     ToolTip="No fill (outline only)" Checked="OnFillChecked" IsChecked="True"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Fill" Tag="Quarter" Content="&#xE7E6;"
                                     ToolTip="25% fill" Checked="OnFillChecked"/>
                        <RadioButton Style="{StaticResource ToolButton}" GroupName="Fill" Tag="Solid" Content="&#xE73B;"
                                     ToolTip="Solid fill" Checked="OnFillChecked"/>
                        <StackPanel x:Name="TextStylePanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                            <Rectangle Style="{StaticResource ToolbarDivider}"/>
                            <TextBlock Text="Style" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="TextStyleBox" Style="{StaticResource DarkComboBox}" Width="92"
                                      SelectedIndex="0" SelectionChanged="OnTextStyleChanged">
                                <ComboBoxItem Content="Plain" Tag="Plain"/>
                                <ComboBoxItem Content="Bold" Tag="Bold"/>
                                <ComboBoxItem Content="Outline" Tag="Outline"/>
                                <ComboBoxItem Content="Pill" Tag="Pill"/>
                                <ComboBoxItem Content="Huge" Tag="Huge"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="CropRatioPanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                            <Rectangle Style="{StaticResource ToolbarDivider}"/>
                            <TextBlock Text="Ratio" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CropRatioBox" Style="{StaticResource DarkComboBox}" Width="88"
                                      SelectedIndex="0" SelectionChanged="OnCropRatioChanged">
                                <ComboBoxItem Content="Free" Tag=""/>
                                <ComboBoxItem Content="1:1" Tag="1:1"/>
                                <ComboBoxItem Content="4:3" Tag="4:3"/>
                                <ComboBoxItem Content="16:9" Tag="16:9"/>
                                <ComboBoxItem Content="9:16" Tag="9:16"/>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ===================== INFINITE CANVAS ===================== -->
        <!-- The content keeps a 1 DIP = 1 source pixel layout and is positioned
             purely by the view transform below, so zoom/pan never touch annotation
             math or the flatten/export path (which renders CanvasHost only). -->
        <Grid x:Name="Viewport" Grid.Row="1" Background="{StaticResource WindowBgBrush}" ClipToBounds="True"
              MouseWheel="OnViewportMouseWheel"
              MouseDown="OnViewportMouseDown"
              MouseMove="OnViewportMouseMove"
              MouseUp="OnViewportMouseUp">
            <Grid x:Name="EditorSurface" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Background="Transparent" Cursor="Cross" RenderTransformOrigin="0,0">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ViewScale"/>
                        <TranslateTransform x:Name="ViewTranslate"/>
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid x:Name="CanvasHost">
                    <Image x:Name="BaseImage" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Canvas x:Name="AnnotationCanvas" Background="Transparent" ClipToBounds="True"/>
                </Grid>
                <Canvas x:Name="InteractionCanvas" IsHitTestVisible="False" ClipToBounds="True">
                    <Path x:Name="CropDim" Fill="#66000000" Visibility="Collapsed"/>
                    <Rectangle x:Name="DragRect" Stroke="{StaticResource InfoBrush}" StrokeThickness="1.5"
                               StrokeDashArray="4 3" Fill="#114DA3FF" Visibility="Collapsed"/>
                    <Rectangle x:Name="SelectionRect" Stroke="{StaticResource InfoBrush}" StrokeThickness="1.5"
                               StrokeDashArray="4 3" Visibility="Collapsed"/>
                    <Ellipse x:Name="CurveHandle" Width="10" Height="10" Fill="{StaticResource InfoBrush}"
                             Stroke="White" StrokeThickness="1.5" Visibility="Collapsed"/>
                    <Border x:Name="EyedropSwatch" Visibility="Collapsed" Background="{StaticResource FloatingBgBrush}"
                            CornerRadius="4" Padding="5" RenderTransformOrigin="0,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle x:Name="EyedropColorRect" Width="14" Height="14" RadiusX="2" RadiusY="2"
                                       Stroke="#88FFFFFF" StrokeThickness="1"/>
                            <TextBlock x:Name="EyedropHexText" Foreground="White" FontSize="11"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>
        </Grid>

        <!-- ===================== BOTTOM UTILITY BAR ===================== -->
        <Border Grid.Row="2" Style="{StaticResource BottomUtilityBar}" Margin="12,6,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: live zoom readout + preset jump -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock x:Name="ZoomLabel" Text="100%" Style="{StaticResource ValueLabel}"
                               MinWidth="42" TextAlignment="Right" Margin="4,0,8,0"
                               ToolTip="Zoom level (mouse wheel to zoom)"/>
                    <ComboBox x:Name="ZoomBox" Style="{StaticResource DarkComboBox}" Width="84"
                              SelectedIndex="0" SelectionChanged="OnZoomPresetChanged"
                              ToolTip="Jump to a zoom level">
                        <ComboBoxItem Content="Fit"/>
                        <ComboBoxItem Content="50%"/>
                        <ComboBoxItem Content="100%"/>
                        <ComboBoxItem Content="150%"/>
                        <ComboBoxItem Content="200%"/>
                    </ComboBox>
                </StackPanel>

                <!-- Center: drag-out handle -->
                <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="{StaticResource RadiusPill}"
                        Padding="12,5" Cursor="SizeAll" MouseLeftButtonDown="OnDragMeDown"
                        ToolTip="Drag this onto another app to drop the image as a file">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE76F;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Drag me" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   Margin="8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE76F;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right: circular quick actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Style="{StaticResource CircleActionButton}" Content="&#xE718;" ToolTip="Pin to screen" Click="OnPin"/>
                    <Button x:Name="BtnCopy" Style="{StaticResource CircleActionButton}" Content="&#xE8C8;" ToolTip="Copy to clipboard (Ctrl+C)" Click="OnCopy"/>
                    <Button x:Name="BtnCenter" Style="{StaticResource CircleActionButton}" Content="&#xE9A6;" ToolTip="Fit &amp; center (Ctrl+0)" Click="OnCenterView"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
