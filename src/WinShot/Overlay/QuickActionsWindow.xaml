<Window x:Class="WinShot.Overlay.QuickActionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" SizeToContent="WidthAndHeight" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False" WindowStartupLocation="Manual">
    <Border Style="{StaticResource FloatingToolbar}" MouseLeftButtonDown="OnDragMove">
        <Grid>
            <StackPanel>
                <!-- Thumbnail (drag-out to other apps) -->
                <Border CornerRadius="{StaticResource RadiusInput}" ClipToBounds="True"
                        HorizontalAlignment="Center">
                    <Image x:Name="Thumb" Stretch="Uniform" MaxWidth="320" MaxHeight="180" Cursor="Hand"
                           MouseLeftButtonDown="OnThumbMouseDown" MouseMove="OnThumbMouseMove"
                           MouseLeftButtonUp="OnThumbMouseUp"/>
                </Border>

                <!-- Split circular action row: Pin (left) · Copy/Edit/Save/OCR/Bg (right) -->
                <DockPanel LastChildFill="False" Margin="0,10,0,0">
                    <Button x:Name="BtnPin" DockPanel.Dock="Left"
                            Style="{StaticResource CircleActionButton}"
                            Content="&#xE718;" Click="OnPin"
                            ToolTip="Pin (P)"/>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="BtnCopy" Style="{StaticResource CircleActionButton}"
                                Content="&#xE8C8;" Click="OnCopy" ToolTip="Copy (C)"/>
                        <Button x:Name="BtnEdit" Style="{StaticResource CircleActionButton}"
                                Content="&#xE70F;" Click="OnEdit" ToolTip="Edit (E)"/>
                        <Button x:Name="BtnSave" Style="{StaticResource CircleActionButton}"
                                Content="&#xE74E;" Click="OnSave" ToolTip="Save (S)"/>
                        <Button x:Name="BtnOcr" Style="{StaticResource CircleActionButton}"
                                Content="&#xE721;" Click="OnOcr" ToolTip="OCR (O)"/>
                        <Button x:Name="BtnBg" Style="{StaticResource CircleActionButton}"
                                Content="&#xEB9F;" Click="OnBackground" ToolTip="Background (B)"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>

            <!-- Optional small close at top-right -->
            <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="22" Height="22" Margin="0,-2,-2,0"
                    Style="{StaticResource CircleActionButton}"
                    Content="&#xE8BB;" FontSize="11" Click="OnClose" ToolTip="Close (Esc)"/>
        </Grid>
    </Border>
</Window>
