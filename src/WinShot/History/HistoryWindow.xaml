<Window x:Class="WinShot.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot — History" Width="840" Height="560" MinWidth="430" MinHeight="320"
        Background="#2B2B2B" ShowInTaskbar="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterChip" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#3A3A3A" CornerRadius="12" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#242424" BorderBrush="#33FFFFFF"
                BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ChipAll" Content="All" IsChecked="True"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipImages" Content="Images"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipVideo" Content="Video"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipGif" Content="GIF"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#242424" BorderBrush="#33FFFFFF"
                BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Margin="0"
                        Style="{StaticResource TileButton}" Click="OnRefresh"/>
                <TextBlock x:Name="CountText" Foreground="#BBBBBB" FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <ListBox x:Name="ItemsList" Background="Transparent" BorderThickness="0" Padding="8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="True"
                 ScrollViewer.IsDeferredScrollingEnabled="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#333333" CornerRadius="8" Margin="0,0,0,8" Padding="8"
                            MouseLeftButtonDown="OnTileMouseDown" MouseEnter="OnTileMouseEnter">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" Click="OnCopy" Visibility="{Binding ImageOnlyVisibility}"/>
                                <MenuItem Header="Edit" Click="OnEdit" Visibility="{Binding ImageOnlyVisibility}"/>
                                <MenuItem Header="Pin" Click="OnPin"/>
                                <MenuItem Header="Open" Click="OnOpen"/>
                                <MenuItem Header="Reveal in Explorer" Click="OnReveal"/>
                                <Separator/>
                                <MenuItem Header="Delete" Click="OnDelete"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="112" Height="70" Background="#222222" CornerRadius="6" ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                           Visibility="{Binding ImageOnlyVisibility}"/>
                                    <TextBlock Text="{Binding ExtensionLabel}" Visibility="{Binding MediaOnlyVisibility}"
                                               Foreground="#4DA3FF" FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" Foreground="#DDDDDD" FontSize="12"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"/>
                                <TextBlock Text="{Binding FilePath}" Foreground="#888888" FontSize="11"
                                           Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Copy" Style="{StaticResource TileButton}" Click="OnCopy"
                                            Visibility="{Binding ImageOnlyVisibility}"/>
                                    <Button Content="Edit" Style="{StaticResource TileButton}" Click="OnEdit"
                                            Visibility="{Binding ImageOnlyVisibility}"/>
                                    <Button Content="Pin" Style="{StaticResource TileButton}" Click="OnPin"/>
                                    <Button Content="Del" Style="{StaticResource TileButton}" Click="OnDelete"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
