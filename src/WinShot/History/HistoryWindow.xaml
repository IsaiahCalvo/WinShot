<Window x:Class="WinShot.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot — History" Width="900" Height="600" MinWidth="480" MinHeight="360"
        Background="{StaticResource WindowBgBrush}" ShowInTaskbar="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Small tile action button (Copy / Edit / Pin / Del), revealed on hover. -->
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusButton}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ElevatedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Centered blue "Restore" pill overlaid on the selected card. -->
        <Style x:Key="RestorePill" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="16,8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12"
                                                  ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <!-- Refresh/restore glyph -->
                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                           FontSize="13" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Restore" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- CleanShot-style filter pill: transparent/subtle when inactive,
             solid accent fill when the segment is selected. -->
        <Style x:Key="FilterChip" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="14" Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource ToolbarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,10">
            <!-- Centered segmented filter pills (CleanShot X style). -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="ChipAll" Content="All" IsChecked="True"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipImages" Content="Screenshots"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipVideo" Content="Videos"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
                <RadioButton x:Name="ChipGif" Content="GIFs"
                             Style="{StaticResource FilterChip}" Checked="OnFilterChanged"/>
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource ToolbarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Refresh" Margin="0"
                        Style="{StaticResource TileButton}" Click="OnRefresh"/>
                <TextBlock x:Name="CountText" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid>
            <!-- Responsive thumbnail grid. WrapPanel inside a vertical ScrollViewer.
                 Virtualization with wrapping is unreliable in WPF, so a plain
                 WrapPanel is used; history is already capped by HistoryLimit. -->
            <ListBox x:Name="ItemsList" Background="Transparent" BorderThickness="0" Padding="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False">
                <ListBox.ItemContainerStyle>
                    <!-- Real selection: containers are focusable so arrow keys move a
                         SelectedItem across the WrapPanel. The selection visual is a thin
                         accent ring around the card (the card keeps its own hover border). -->
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="True"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <!-- The ring carries the inter-tile spacing (margin) and
                                     hugs the card edge; selection lights its accent border. -->
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="SelectionRing" Margin="6"
                                            BorderBrush="Transparent" BorderThickness="2"
                                            CornerRadius="{StaticResource RadiusCard}"
                                            Background="Transparent">
                                        <Grid>
                                            <ContentPresenter/>
                                            <!-- Centered blue Restore pill, shown only on the
                                                 selected card. Wired to the existing open action. -->
                                            <Button x:Name="RestoreOverlay"
                                                    Style="{StaticResource RestorePill}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="Collapsed"
                                                    Click="OnOpen"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionRing" Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="RestoreOverlay" Property="Visibility"
                                                    Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <!-- Groups stack vertically (StackPanel); tiles wrap within each group. -->
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <!-- Small uppercase secondary-text day header. -->
                                <TextBlock Text="{Binding Name}" Margin="9,12,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.Panel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Square-ish card: large thumbnail + thin caption.
                             Action row revealed on hover (named OverlayActions). -->
                        <Border x:Name="Card" Width="190" Margin="0"
                                Background="{StaticResource ToolbarBgBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusCard}" ClipToBounds="True"
                                MouseLeftButtonDown="OnTileMouseDown"
                                MouseMove="OnTileMouseMove"
                                MouseEnter="OnTileMouseEnter">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource DarkContextMenu}">
                                    <MenuItem Header="Copy" Click="OnCopy" Visibility="{Binding ImageOnlyVisibility}" Style="{StaticResource DarkMenuItem}"/>
                                    <MenuItem Header="Edit" Click="OnEdit" Visibility="{Binding ImageOnlyVisibility}" Style="{StaticResource DarkMenuItem}"/>
                                    <MenuItem Header="Pin" Click="OnPin" Style="{StaticResource DarkMenuItem}"/>
                                    <MenuItem Header="Open" Click="OnOpen" Style="{StaticResource DarkMenuItem}"/>
                                    <MenuItem Header="Reveal in Explorer" Click="OnReveal" Style="{StaticResource DarkMenuItem}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete" Click="OnDelete" Style="{StaticResource DarkMenuItem}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="130"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail fills the card top. -->
                                <Border Grid.Row="0" Background="{StaticResource WindowBgBrush}" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                               Visibility="{Binding ImageOnlyVisibility}"/>
                                        <TextBlock Text="{Binding ExtensionLabel}" Visibility="{Binding MediaOnlyVisibility}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <!-- Hover action row, anchored bottom of the thumbnail. -->
                                        <Border x:Name="OverlayActions" VerticalAlignment="Bottom"
                                                Background="#CC000000" Padding="6,5" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="Copy" Style="{StaticResource TileButton}" Click="OnCopy"
                                                        Visibility="{Binding ImageOnlyVisibility}"/>
                                                <Button Content="Edit" Style="{StaticResource TileButton}" Click="OnEdit"
                                                        Visibility="{Binding ImageOnlyVisibility}"/>
                                                <Button Content="Pin" Style="{StaticResource TileButton}" Click="OnPin"/>
                                                <Button Content="Del" Style="{StaticResource TileButton}" Click="OnDelete"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Centered relative-time caption ("1 minute ago"),
                                     CleanShot X style. Filename/size kept as the tooltip. -->
                                <StackPanel Grid.Row="1" Margin="10,8,10,10">
                                    <TextBlock Text="{Binding RelativeTime}" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Caption}"/>
                                </StackPanel>
                            </Grid>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OverlayActions"
                                                                           Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OverlayActions"
                                                                           Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state: centered hint when there are no items. -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <TextBlock Text="&#xE91B;" FontFamily="{StaticResource IconFont}"
                           FontSize="48" Foreground="{StaticResource TextDisabledBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="No captures yet" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="Screenshots and recordings you take will show up here."
                           Foreground="{StaticResource TextDisabledBrush}"
                           FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
