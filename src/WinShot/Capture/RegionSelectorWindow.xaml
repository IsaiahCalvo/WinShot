<Window x:Class="WinShot.Capture.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="100" Height="100"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="Manual"
        ShowInTaskbar="False" Topmost="True" Background="Black" Cursor="Cross"
        Focusable="True" ShowActivated="True">
    <Grid x:Name="Root">
        <Image x:Name="ScreenshotImage" Stretch="Fill"/>
        <Canvas x:Name="OverlayCanvas">
            <Path x:Name="DimPath" Fill="#59000000"/>
            <Rectangle x:Name="WindowHighlight" Stroke="#FF4DA3FF" StrokeThickness="2"
                       Fill="#1A4DA3FF" Visibility="Collapsed"/>
            <Rectangle x:Name="SelectionRect" Stroke="White" StrokeThickness="1.5"
                       Fill="Transparent" Visibility="Collapsed"/>
            <Border x:Name="SizeLabel" Background="#CC1E1E1E" CornerRadius="4"
                    Padding="6,2" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Consolas"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
