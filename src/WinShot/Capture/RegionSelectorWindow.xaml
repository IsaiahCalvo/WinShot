<Window x:Class="WinShot.Capture.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="100" Height="100"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="Manual"
        ShowInTaskbar="False" Topmost="True" AllowsTransparency="True"
        Background="Transparent" Cursor="Cross"
        Focusable="True" ShowActivated="True">
    <Window.Resources>
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LockToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SizeBox" TargetType="TextBox">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2D7DFF"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </Window.Resources>
    <Grid x:Name="Root" Background="Transparent" SnapsToDevicePixels="True">
        <Image x:Name="ScreenshotImage" Stretch="Fill" IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="LowQuality"/>
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Path x:Name="DimPath" Fill="#59000000"/>
            <Rectangle x:Name="WindowHighlight" Stroke="#FF4DA3FF" StrokeThickness="2"
                       Fill="#1A4DA3FF" Visibility="Collapsed"/>
            <Rectangle x:Name="SelectionRect" Stroke="White" StrokeThickness="1.5"
                       Fill="Transparent" Visibility="Collapsed"/>
            <Border x:Name="SizeLabel" Background="#CC1E1E1E" CornerRadius="4"
                    Padding="6,2" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Consolas"/>
            </Border>
            <Canvas x:Name="Loupe" Visibility="Collapsed" IsHitTestVisible="False">
                <Ellipse Width="120" Height="120" Stroke="#CCFFFFFF" StrokeThickness="2"
                         RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="LoupeBrush" ViewboxUnits="Absolute" Stretch="Fill"/>
                    </Ellipse.Fill>
                </Ellipse>
                <Line X1="60" Y1="4" X2="60" Y2="116" Stroke="#CC4DA3FF" StrokeThickness="1"/>
                <Line X1="4" Y1="60" X2="116" Y2="60" Stroke="#CC4DA3FF" StrokeThickness="1"/>
                <Border Canvas.Left="18" Canvas.Top="124" Background="#CC1E1E1E" CornerRadius="4" Padding="6,2">
                    <TextBlock x:Name="LoupeCoords" Foreground="White" FontSize="11" FontFamily="Consolas"/>
                </Border>
            </Canvas>
        </Canvas>
        <Border x:Name="Toolbar" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,18,0,0" CornerRadius="20" Background="#F22B2B2B"
                BorderBrush="#33FFFFFF" BorderThickness="1" Padding="12,6" Cursor="Arrow">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="ModeArea" Style="{StaticResource ModeRadio}" GroupName="AioMode"
                             Content="Area" IsChecked="True" Checked="OnModeChecked"/>
                <RadioButton x:Name="ModeWindow" Style="{StaticResource ModeRadio}" GroupName="AioMode"
                             Content="Window" Checked="OnModeChecked"/>
                <Button x:Name="BtnFullscreen" Style="{StaticResource ToolButton}" Content="Fullscreen"
                        Click="OnFullscreen"/>
                <RadioButton x:Name="ModeRecord" Style="{StaticResource ModeRadio}" GroupName="AioMode"
                             Content="Record" Checked="OnModeChecked"/>
                <RadioButton x:Name="ModeOcr" Style="{StaticResource ModeRadio}" GroupName="AioMode"
                             Content="OCR" Checked="OnModeChecked"/>
                <RadioButton x:Name="ModeScroll" Style="{StaticResource ModeRadio}" GroupName="AioMode"
                             Content="Scroll" Checked="OnModeChecked"/>
                <Rectangle Width="1" Fill="#33FFFFFF" Margin="8,2"/>
                <TextBox x:Name="WBox" Style="{StaticResource SizeBox}" KeyDown="OnSizeBoxKeyDown"
                         ToolTip="Width in pixels — press Enter to apply"/>
                <TextBlock Text="×" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox x:Name="HBox" Style="{StaticResource SizeBox}" KeyDown="OnSizeBoxKeyDown"
                         ToolTip="Height in pixels — press Enter to apply"/>
                <ToggleButton x:Name="AspectLock" Style="{StaticResource LockToggle}" Content="🔒" Margin="6,0,0,0"
                              ToolTip="Lock drag to the W : H aspect ratio in the boxes"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
