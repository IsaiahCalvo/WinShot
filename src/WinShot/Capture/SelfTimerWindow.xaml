<Window x:Class="WinShot.Capture.SelfTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" SizeToContent="WidthAndHeight" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        WindowStartupLocation="CenterScreen" IsHitTestVisible="False">
    <Border Width="150" Height="150" CornerRadius="75" Background="#E51E1E1E"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <TextBlock x:Name="CountText" Foreground="White" FontSize="72" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</Window>
