<Window x:Class="WinShot.SettingsUi.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinShot.SettingsUi"
        Title="WinShot - Settings" Width="580" Height="520"
        Background="#2B2B2B" ResizeMode="CanMinimize" ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="185"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2D7DFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="{x:Type local:HotkeyBox}" BasedOn="{StaticResource {x:Type TextBox}}"/>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#2D7DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4DA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="#3A3A3A" BorderBrush="#555555"
                                                BorderThickness="1" CornerRadius="4">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,8,0" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#BBBBBB"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#454545"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="8,0,24,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#2F2F2F" BorderBrush="#555555" BorderThickness="1"
                                        CornerRadius="4" Margin="0,2,0,0" MaxHeight="220"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Transparent" Margin="0"/>
                            <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="0,6,6,6" Padding="16,12">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6,6,0,0"
                                Padding="14,7" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="16,12,16,16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" MinWidth="80" Style="{StaticResource ActionButton}" Click="OnCancel"/>
            <Button x:Name="SaveButton" Content="Save" MinWidth="80" Style="{StaticResource AccentButton}" Click="OnSave"/>
        </StackPanel>
        <TabControl x:Name="Tabs">
            <TabItem Header="General">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Save folder"/>
                        <Button DockPanel.Dock="Right" Content="Browse..." Style="{StaticResource ActionButton}" Click="OnBrowse"/>
                        <TextBox x:Name="SaveFolderBox"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Image format"/>
                        <ComboBox x:Name="FormatCombo" Width="90" HorizontalAlignment="Left"
                                  Style="{StaticResource DarkCombo}" SelectionChanged="OnFormatChanged">
                            <ComboBoxItem Content="png" Tag="png"/>
                            <ComboBoxItem Content="jpg" Tag="jpg"/>
                            <ComboBoxItem Content="webp" Tag="webp"/>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Copy capture to clipboard"/>
                        <CheckBox x:Name="AutoCopyCheck" Content="Automatically after every capture"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="After capture"/>
                        <ComboBox x:Name="PostActionCombo" Width="160" HorizontalAlignment="Left"
                                  Style="{StaticResource DarkCombo}">
                            <ComboBoxItem Content="Show overlay" Tag="overlay"/>
                            <ComboBoxItem Content="Copy only" Tag="copy"/>
                            <ComboBoxItem Content="Save silently" Tag="save"/>
                            <ComboBoxItem Content="Open editor" Tag="edit"/>
                            <ComboBoxItem Content="Pin to screen" Tag="pin"/>
                            <ComboBoxItem Content="Open background" Tag="background"/>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Overlay auto-close (seconds)"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="OverlayCloseBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="0 = stay until dismissed"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Launch at startup"/>
                        <CheckBox x:Name="StartupCheck" Content="Start WinShot when I sign in"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Desktop icons"/>
                        <CheckBox x:Name="HideIconsCheck" Content="Hide desktop icons during capture"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="HiDPI captures"/>
                        <CheckBox x:Name="HiDpiCheck" Content="Downscale captures from >100% DPI displays"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Hotkeys">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Capture region / window"/>
                        <local:HotkeyBox x:Name="HotkeyRegionBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Capture fullscreen"/>
                        <local:HotkeyBox x:Name="HotkeyFullscreenBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Record screen"/>
                        <local:HotkeyBox x:Name="HotkeyRecordBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Capture text (OCR)"/>
                        <local:HotkeyBox x:Name="HotkeyOcrBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Scrolling capture"/>
                        <local:HotkeyBox x:Name="HotkeyScrollingBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Repeat previous region"/>
                        <local:HotkeyBox x:Name="HotkeyPreviousBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="All-in-one capture"/>
                        <local:HotkeyBox x:Name="HotkeyAllInOneBox" Width="160" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <TextBlock Style="{StaticResource Hint}" Margin="0,10,0,0"
                               Text="Click a field and press the keys. Esc cancels, Backspace clears."/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Recording">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Recording frame rate"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="RecordingFpsBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="10-60 fps"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="GIF frame rate"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="GifFpsBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="5-20 fps"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Microphone"/>
                        <CheckBox x:Name="RecordAudioCheck" Content="Capture microphone while recording"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="System audio"/>
                        <CheckBox x:Name="SystemAudioCheck" Content="Capture system sound while recording"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Webcam overlay"/>
                        <ComboBox x:Name="WebcamCombo" Width="140" HorizontalAlignment="Left"
                                  Style="{StaticResource DarkCombo}">
                            <ComboBoxItem Content="Off" Tag="off"/>
                            <ComboBoxItem Content="Top left" Tag="top-left"/>
                            <ComboBoxItem Content="Top right" Tag="top-right"/>
                            <ComboBoxItem Content="Bottom left" Tag="bottom-left"/>
                            <ComboBoxItem Content="Bottom right" Tag="bottom-right"/>
                            <ComboBoxItem Content="Fullscreen" Tag="fullscreen"/>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Webcam size"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="WebcamSizeBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="10-45%"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Click highlights"/>
                        <CheckBox x:Name="ClickHighlightsCheck" Content="Show a ring around mouse clicks"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Keystroke overlay"/>
                        <CheckBox x:Name="KeystrokesCheck" Content="Show pressed keys on screen"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Countdown before recording"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="CountdownBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="seconds, 0 = start immediately"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Cursor"/>
                        <CheckBox x:Name="CaptureCursorCheck" Content="Include mouse cursor in recordings"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Naming">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="File name template"/>
                        <TextBox x:Name="TemplateBox" TextChanged="OnTemplateChanged"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Preview"/>
                        <TextBlock x:Name="TemplatePreviewText" Foreground="#4DA3FF" FontSize="12"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                    <TextBlock Foreground="#4DA3FF" FontSize="13" FontWeight="SemiBold"
                               Margin="0,14,0,6" Text="Tokens"/>
                    <TextBlock FontSize="11" Foreground="#999999" LineHeight="19">
                        <Run Foreground="#DDDDDD" Text="{}{date}"/><Run Text="  - current date"/><LineBreak/>
                        <Run Foreground="#DDDDDD" Text="{}{time}"/><Run Text="  - current time"/><LineBreak/>
                        <Run Foreground="#DDDDDD" Text="{}{n}"/><Run Text="  - auto-incrementing counter"/><LineBreak/>
                        <Run Foreground="#DDDDDD" Text="{}{app}"/><Run Text="  - active application name"/><LineBreak/>
                        <Run Foreground="#DDDDDD" Text="{}{title}"/><Run Text="  - active window title"/>
                    </TextBlock>
                </StackPanel>
            </TabItem>
            <TabItem Header="History">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="History limit"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="HistoryLimitBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="items kept"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Delete entries older than"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="RetentionDaysBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="days, 0 = prune by count only"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Self-timer delay"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="SelfTimerBox" Width="70"/>
                            <TextBlock Style="{StaticResource Hint}" Text="seconds before a timed capture"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
