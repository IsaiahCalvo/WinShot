<Window x:Class="WinShot.SettingsUi.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinShot.SettingsUi"
        Title="WinShot - Settings" Width="600" Height="700"
        Background="{StaticResource WindowBgBrush}" ResizeMode="CanMinimize" ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Row label: fixed-width, RIGHT-aligned caption (CleanShot's "label:" column). -->
        <Style x:Key="RowLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <!-- Hint: muted helper text, sits under or beside a control. -->
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Full-width hint that sits below a control, indented to the control column. -->
        <Style x:Key="SubHint" TargetType="TextBlock" BasedOn="{StaticResource Hint}">
            <Setter Property="Margin" Value="162,1,0,2"/>
        </Style>

        <!-- Implicit input styling so every box/combo/checkbox in the sections inherits
             the themed treatment without per-control Style= attributes.
             Foreground / CaretBrush / SelectionBrush are set EXPLICITLY here (not only via
             BasedOn) because this style replaces the template; that guarantees typed text is
             light and clearly visible on the dark input surface. -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="CaretBrush" Value="#FFFFFFFF"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bg" Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusInput}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource SettingsTextBox}"/>
        <!-- HotkeyBox inherits the readable input look but adds a muted "Record shortcut"
             placeholder when no gesture is assigned (matches CleanShot's recorder pills). -->
        <Style TargetType="{x:Type local:HotkeyBox}" BasedOn="{StaticResource SettingsTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type local:HotkeyBox}">
                        <Border x:Name="Bg" Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="{StaticResource RadiusInput}">
                            <Grid>
                                <TextBlock x:Name="Placeholder" Text="Record shortcut"
                                           Margin="8,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextDisabledBrush}"
                                           FontSize="12" FontWeight="Normal"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource DarkCheckBox}">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Slider" BasedOn="{StaticResource DarkSlider}"/>

        <!-- A grouped settings card. Compact padding for CleanShot-tight rhythm. -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ToolbarBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}"/>
            <Setter Property="Padding" Value="14,8,14,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- One settings row: label + control, tight vertical rhythm. -->
        <Style x:Key="Row" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="LastChildFill" Value="True"/>
        </Style>

        <!-- Category header used on the Shortcuts list (small, muted, all-caps feel). -->
        <Style x:Key="ShortcutCategory" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,2,0,6"/>
        </Style>

        <!-- Hairline separator between groups within a card (CleanShot's inset dividers). -->
        <Style x:Key="GroupSep" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Top tab: Fluent glyph stacked above a small label. Active tab tints accent,
             matching CleanShot's icon-over-label tab strip. -->
        <Style x:Key="NavTab" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                Padding="10,6" MinWidth="62">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverFillBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A single icon-over-label tab cell. -->
        <Style x:Key="NavTabIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="NavTabLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Sub-tab pill (Recording: General / Video / GIF). -->
        <Style x:Key="SubTab" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                Padding="14,4" Margin="2,0">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverFillBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Column header for the "After capture" matrix. -->
        <Style x:Key="MatrixColHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- A centered checkbox (no label) for the matrix cells. -->
        <Style x:Key="MatrixCheck" TargetType="CheckBox" BasedOn="{StaticResource DarkCheckBox}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="0">

        <!-- =============================== TOP TAB BAR =============================== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource WindowBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <ListBox x:Name="SectionList" Background="Transparent" BorderThickness="0"
                     Padding="8,10" HorizontalAlignment="Center"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource NavTab}"
                     SelectedIndex="0" SelectionChanged="OnSectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE713;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="General"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE765;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Shortcuts"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE7C4;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Quick Access"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE714;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Recording"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE722;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Screenshots"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE70F;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Annotate"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE90F;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="Advanced"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Style="{StaticResource NavTabIcon}" Text="&#xE946;"/>
                        <TextBlock Style="{StaticResource NavTabLabel}" Text="About"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </Border>

        <!-- =============================== CONTENT PANE =============================== -->
        <DockPanel Margin="18,14,18,14">
            <!-- Footer action bar -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource PillButtonSecondary}" Click="OnCancel"/>
                    <Button x:Name="SaveButton" Content="Save" Style="{StaticResource PillButtonPrimary}" Click="OnSave"/>
                </StackPanel>
            </Border>

            <!-- Sections (only one visible at a time; toggled from OnSectionChanged) -->
            <Grid>
                <!-- ===================== GENERAL ===================== -->
                <ScrollViewer x:Name="SectionGeneral" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Startup"/>
                                    <CheckBox x:Name="StartupCheck" Content="Start at login"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Updates"/>
                                    <CheckBox x:Name="UpdatesCheck" Content="Check for updates on startup"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Sounds"/>
                                    <CheckBox x:Name="PlaySoundsCheck" Content="Play sounds"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Shutter sound"/>
                                    <ComboBox x:Name="ShutterSoundCombo" Width="170" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Default" Tag="default"/>
                                        <ComboBoxItem Content="Classic" Tag="classic"/>
                                        <ComboBoxItem Content="Subtle" Tag="subtle"/>
                                        <ComboBoxItem Content="Silent" Tag="silent"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="System tray"/>
                                    <CheckBox x:Name="ShowTrayIconCheck" Content="Show icon"/>
                                </DockPanel>

                                <Rectangle Style="{StaticResource GroupSep}"/>

                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Export location"/>
                                    <Button DockPanel.Dock="Right" Content="Browse..." MinWidth="84"
                                            Style="{StaticResource PillButtonSecondary}" Click="OnBrowse"/>
                                    <TextBox x:Name="SaveFolderBox" Margin="0,0,8,0"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Desktop icons"/>
                                    <CheckBox x:Name="HideIconsCheck" Content="Hide while capturing"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- The signature CleanShot "After capture" matrix. -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="After capture"
                                               VerticalAlignment="Top"/>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                               TextWrapping="Wrap" VerticalAlignment="Top"
                                               Text="Here you can decide what should happen after taking a screenshot or recording a video."/>
                                </DockPanel>

                                <Border Margin="162,8,0,0" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="{StaticResource RadiusInput}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78"/>
                                            <ColumnDefinition Width="78"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="28"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header row -->
                                        <Border Grid.Row="0" Grid.ColumnSpan="3"
                                                Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="8,8,0,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MatrixColHead}" Text="Screenshot"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MatrixColHead}" Text="Recording"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource MatrixColHead}"
                                                   HorizontalAlignment="Left" Margin="10,0,0,0" Text="Action"/>

                                        <!-- Row: Show Quick Access Overlay -->
                                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="ScreenshotShowOverlayCheck" Style="{StaticResource MatrixCheck}"/>
                                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="RecordingShowOverlayCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Show Quick Access Overlay"/>

                                        <!-- Row: Copy file to clipboard -->
                                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="ScreenshotCopyCheck" Style="{StaticResource MatrixCheck}"/>
                                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="RecordingCopyCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Copy file to clipboard"/>

                                        <!-- Row: Save -->
                                        <CheckBox Grid.Row="3" Grid.Column="0" x:Name="ScreenshotSaveCheck" Style="{StaticResource MatrixCheck}"/>
                                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="RecordingSaveCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Save"/>

                                        <!-- Row: Open Annotate tool (screenshot only) -->
                                        <CheckBox Grid.Row="4" Grid.Column="0" x:Name="ScreenshotOpenAnnotateCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextDisabledBrush}" Text="—"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Open Annotate tool"/>

                                        <!-- Row: Pin to the screen (screenshot only) -->
                                        <CheckBox Grid.Row="5" Grid.Column="0" x:Name="ScreenshotPinCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextDisabledBrush}" Text="—"/>
                                        <TextBlock Grid.Row="5" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Pin to the screen"/>

                                        <!-- Row: Open Video Editor (recording only) -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextDisabledBrush}" Text="—"/>
                                        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="RecordingOpenEditorCheck" Style="{StaticResource MatrixCheck}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="2" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Text="Open Video Editor"/>

                                        <!-- Hidden screenshot-editor checkbox kept for parity/persistence (Open Annotate == screenshot editor). -->
                                        <CheckBox x:Name="ScreenshotOpenEditorCheck" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== SHORTCUTS ===================== -->
                <ScrollViewer x:Name="SectionShortcuts" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <!-- Rows are generated from the shortcut catalog in
                                     SettingsWindow.Shortcuts.cs (BuildShortcutsTab). -->
                                <StackPanel x:Name="ShortcutsHost"/>
                                <TextBlock Style="{StaticResource Hint}" Margin="0,12,0,2"
                                           Text="Click a field and press the keys. Esc cancels, Backspace clears."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== QUICK ACCESS (overlay) ===================== -->
                <ScrollViewer x:Name="SectionQuickAccess" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Position on screen"/>
                                    <ComboBox x:Name="OverlayPositionCombo" Width="170" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Left" Tag="left"/>
                                        <ComboBoxItem Content="Right" Tag="right"/>
                                        <ComboBoxItem Content="Top" Tag="top"/>
                                        <ComboBoxItem Content="Bottom" Tag="bottom"/>
                                        <ComboBoxItem Content="Bottom Left" Tag="bottom-left"/>
                                        <ComboBoxItem Content="Bottom Right" Tag="bottom-right"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Multi-display"/>
                                    <CheckBox x:Name="OverlayMoveToActiveScreenCheck" Content="Move to active screen"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Active screen is the screen where your cursor is pointing."/>
                                <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Overlay size"/>
                                    <Slider x:Name="OverlaySizeSlider" Width="220" HorizontalAlignment="Left"
                                            Minimum="0" Maximum="100" Value="50"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Auto-close"/>
                                    <CheckBox x:Name="OverlayAutoCloseCheck" Content="Enable"
                                              Checked="OnOverlayAutoCloseToggled" Unchecked="OnOverlayAutoCloseToggled"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Action"/>
                                    <ComboBox x:Name="OverlayActionCombo" Width="170" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Save and Close" Tag="save-close"/>
                                        <ComboBoxItem Content="Copy and Close" Tag="copy-close"/>
                                        <ComboBoxItem Content="Close" Tag="close"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Interval"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="OverlayCloseBox" Width="80"/>
                                        <TextBlock Style="{StaticResource Hint}" Text="seconds before it closes"/>
                                    </StackPanel>
                                </DockPanel>

                                <Rectangle Style="{StaticResource GroupSep}"/>

                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Drag &amp; drop"/>
                                    <CheckBox x:Name="OverlayCloseAfterDragCheck" Content="Close after dragging"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Hold Alt to keep the item on the Overlay after dragging."/>
                                <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Save button behavior"/>
                                    <ComboBox x:Name="OverlaySaveBehaviorCombo" Width="200" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Save to &quot;Export location&quot;" Tag="export"/>
                                        <ComboBoxItem Content="Always ask where to save" Tag="ask"/>
                                    </ComboBox>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Press with Alt to choose the destination."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== RECORDING ===================== -->
                <ScrollViewer x:Name="SectionRecording" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Sub-tab strip: General / Video / GIF -->
                        <ListBox x:Name="RecordingSubList" Background="Transparent" BorderThickness="0"
                                 HorizontalAlignment="Center" Margin="0,0,0,10"
                                 ItemContainerStyle="{StaticResource SubTab}"
                                 SelectedIndex="0" SelectionChanged="OnRecordingSubChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBoxItem Content="General"/>
                            <ListBoxItem Content="Video"/>
                            <ListBoxItem Content="GIF"/>
                        </ListBox>

                        <!-- Recording > General -->
                        <StackPanel x:Name="RecordingGeneralPanel">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Controls"/>
                                        <CheckBox x:Name="ShowRecordingControlsCheck" Content="Show controls while recording"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="System tray"/>
                                        <CheckBox x:Name="ShowRecordingTimerCheck" Content="Display recording time"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="HiDPI"/>
                                        <CheckBox x:Name="ScaleHiDpiVideoCheck" Content="Scale HiDPI videos to 1x"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Notifications"/>
                                        <CheckBox x:Name="DoNotDisturbCheck" Content="Silence notifications while recording"/>
                                    </DockPanel>

                                    <Rectangle Style="{StaticResource GroupSep}"/>

                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Cursor"/>
                                        <CheckBox x:Name="CaptureCursorCheck" Content="Show cursor"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                        <CheckBox x:Name="ClickHighlightsCheck" Content="Highlight clicks"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Keyboard"/>
                                        <CheckBox x:Name="KeystrokesCheck" Content="Show keystrokes"/>
                                    </DockPanel>

                                    <Rectangle Style="{StaticResource GroupSep}"/>

                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Recording area"/>
                                        <CheckBox x:Name="RememberLastSelectionCheck" Content="Remember last selection"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                        <CheckBox x:Name="DimScreenCheck" Content="Dim screen while recording"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                        <CheckBox x:Name="ShowCountdownCheck" Content="Show countdown"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Countdown"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="CountdownBox" Width="80"/>
                                            <TextBlock Style="{StaticResource Hint}" Text="seconds, 0 = start immediately"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Rectangle Style="{StaticResource GroupSep}"/>

                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Webcam"/>
                                        <ComboBox x:Name="WebcamCombo" Width="180" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Off" Tag="off"/>
                                            <ComboBoxItem Content="Top left" Tag="top-left"/>
                                            <ComboBoxItem Content="Top right" Tag="top-right"/>
                                            <ComboBoxItem Content="Bottom left" Tag="bottom-left"/>
                                            <ComboBoxItem Content="Bottom right" Tag="bottom-right"/>
                                            <ComboBoxItem Content="Fullscreen" Tag="fullscreen"/>
                                        </ComboBox>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Webcam size"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="WebcamSizeBox" Width="80"/>
                                            <TextBlock Style="{StaticResource Hint}" Text="10-45%"/>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Recording > Video -->
                        <StackPanel x:Name="RecordingVideoPanel" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Max resolution"/>
                                        <ComboBox x:Name="MaxResolutionCombo" Width="150" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Original" Tag="original"/>
                                            <ComboBoxItem Content="4K" Tag="4k"/>
                                            <ComboBoxItem Content="1080p" Tag="1080p"/>
                                            <ComboBoxItem Content="720p" Tag="720p"/>
                                        </ComboBox>
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource SubHint}"
                                               Text="Set maximum resolution to reduce file size and upload time."/>

                                    <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Video FPS"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="RecordingFpsBox" Width="80"/>
                                            <TextBlock Style="{StaticResource Hint}" Text="10-60 fps"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Rectangle Style="{StaticResource GroupSep}"/>

                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Audio"/>
                                        <CheckBox x:Name="RecordAudioCheck" Content="Capture microphone while recording"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                        <CheckBox x:Name="SystemAudioCheck" Content="Capture system sound while recording"/>
                                    </DockPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                        <CheckBox x:Name="RecordAudioMonoCheck" Content="Record audio in mono"/>
                                    </DockPanel>

                                    <Rectangle Style="{StaticResource GroupSep}"/>

                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Video Encoder"/>
                                        <CheckBox x:Name="OpenVideoEditorCheck" Content="Open Video Editor after recording"/>
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource SubHint}"
                                               Text="Use Video Editor to change the recording quality, resolution and adjust audio settings."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Recording > GIF -->
                        <StackPanel x:Name="RecordingGifPanel" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Style="{StaticResource Row}">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="GIF FPS"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="GifFpsBox" Width="80"/>
                                            <TextBlock Style="{StaticResource Hint}" Text="5-20 fps"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="GIF quality"/>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Width="180">
                                                <Slider x:Name="GifQualitySlider" Minimum="0" Maximum="100" Value="80"/>
                                                <Grid Margin="2,1,2,0">
                                                    <TextBlock Style="{StaticResource Hint}" Margin="0" HorizontalAlignment="Left" Text="Low"/>
                                                    <TextBlock Style="{StaticResource Hint}" Margin="0" HorizontalAlignment="Right" Text="High"/>
                                                </Grid>
                                            </StackPanel>
                                            <CheckBox x:Name="OptimizeGifsCheck" Content="Optimize GIFs" Margin="14,0,0,0" VerticalAlignment="Top"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource SubHint}"
                                               Text="Setting the quality to maximum can speed up the processing time, but it will increase file size."/>

                                    <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="GIF size"/>
                                        <ComboBox x:Name="GifSizeCombo" Width="190" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="800 x auto (default)" Tag="800"/>
                                            <ComboBoxItem Content="640 x auto" Tag="640"/>
                                            <ComboBoxItem Content="480 x auto" Tag="480"/>
                                            <ComboBoxItem Content="Original" Tag="auto"/>
                                        </ComboBox>
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource SubHint}"
                                               Text="Set maximum resolution of your GIFs. Changing it will affect file size and quality. WinShot will only downscale the GIF if needed."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== SCREENSHOTS ===================== -->
                <ScrollViewer x:Name="SectionScreenshots" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="File format"/>
                                    <ComboBox x:Name="FormatCombo" Width="110" HorizontalAlignment="Left"
                                              SelectionChanged="OnFormatChanged">
                                        <ComboBoxItem Content="PNG" Tag="png"/>
                                        <ComboBoxItem Content="JPG" Tag="jpg"/>
                                        <ComboBoxItem Content="WEBP" Tag="webp"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="HiDPI"/>
                                    <CheckBox x:Name="HiDpiCheck" Content="Scale HiDPI screenshots to 1x"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Color management"/>
                                    <CheckBox x:Name="ConvertToSrgbCheck" Content="Convert to sRGB profile"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Frame"/>
                                    <CheckBox x:Name="AddPixelBorderCheck" Content="Add 1px border to all screenshots"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Background"/>
                                    <ComboBox x:Name="BackgroundCombo" Width="170" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="None" Tag="none"/>
                                        <ComboBoxItem Content="Wallpaper" Tag="wallpaper"/>
                                        <ComboBoxItem Content="Gradient" Tag="gradient"/>
                                        <ComboBoxItem Content="Solid color" Tag="color"/>
                                    </ComboBox>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Apply Background Tool to all screenshots. Create presets in Annotate. Hold Shift while taking a screenshot to disable."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Self-Timer interval"/>
                                    <ComboBox x:Name="SelfTimerCombo" Width="150" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="3 Seconds" Tag="3"/>
                                        <ComboBoxItem Content="5 Seconds" Tag="5"/>
                                        <ComboBoxItem Content="10 Seconds" Tag="10"/>
                                        <ComboBoxItem Content="15 Seconds" Tag="15"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Cursor"/>
                                    <CheckBox x:Name="CursorOnScreenshotsCheck" Content="Show on screenshots"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="This works in Fullscreen or Self-Timer modes only."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Freeze screen"/>
                                    <CheckBox x:Name="FreezeScreenCheck" Content="Freeze screen when taking a screenshot"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Crosshair mode"/>
                                    <ComboBox x:Name="CrosshairModeCombo" Width="200" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Always show" Tag="always"/>
                                        <ComboBoxItem Content="When Ctrl is pressed" Tag="command"/>
                                        <ComboBoxItem Content="Never" Tag="never"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                    <CheckBox x:Name="ShowMagnifierCheck" Content="Show magnifier"/>
                                </DockPanel>
                                <!-- Legacy "Show crosshair" toggle kept for persistence; folded into Crosshair mode. -->
                                <CheckBox x:Name="ShowCrosshairCheck" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== ANNOTATE ===================== -->
                <ScrollViewer x:Name="SectionAnnotate" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Arrow tool"/>
                                    <CheckBox x:Name="InverseArrowCheck" Content="Inverse arrow direction"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Press Alt when drawing to invert the behavior."/>
                                <DockPanel Style="{StaticResource Row}" Margin="0,8,0,4">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Pencil tool"/>
                                    <CheckBox x:Name="SmoothPencilCheck" Content="Smooth drawing"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Background tool"/>
                                    <CheckBox x:Name="RememberLastToolCheck" Content="Remember if tool was opened"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Shadow"/>
                                    <CheckBox x:Name="DrawShadowCheck" Content="Draw shadow on objects"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Canvas"/>
                                    <CheckBox x:Name="AutoExpandCanvasCheck" Content="Automatically expand"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Ensures all annotations fit by dynamically resizing canvas."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Accessibility"/>
                                    <CheckBox x:Name="ShowColorNamesCheck" Content="Show color names"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Window"/>
                                    <CheckBox x:Name="AlwaysOnTopCheck" Content="Always on top"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                    <CheckBox x:Name="ShowDockIconCheck" Content="Show taskbar icon"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== ADVANCED ===================== -->
                <ScrollViewer x:Name="SectionAdvanced" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="File name"/>
                                    <TextBox x:Name="TemplateBox" TextChanged="OnTemplateChanged"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Preview"/>
                                    <TextBlock x:Name="TemplatePreviewText" Foreground="{StaticResource AccentBrush}"
                                               FontSize="12" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                    <CheckBox x:Name="AskForNameCheck" Content="Ask for name after every capture"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                    <CheckBox x:Name="AddRetinaSuffixCheck" Content="Add &quot;@2x&quot; suffix to HiDPI screenshots"/>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           LineHeight="17" Margin="162,4,0,0">
                                    <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{}{date}"/><Run Text="  current date"/><LineBreak/>
                                    <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{}{time}"/><Run Text="  current time"/><LineBreak/>
                                    <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{}{n}"/><Run Text="  auto-incrementing counter"/><LineBreak/>
                                    <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{}{app}"/><Run Text="  active application name"/><LineBreak/>
                                    <Run Foreground="{StaticResource TextPrimaryBrush}" Text="{}{title}"/><Run Text="  active window title"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Copy to clipboard"/>
                                    <ComboBox x:Name="CopyFormatCombo" Width="200" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="File &amp; image (default)" Tag="file-image"/>
                                        <ComboBoxItem Content="File only" Tag="file"/>
                                        <ComboBoxItem Content="Image only" Tag="image"/>
                                    </ComboBox>
                                </DockPanel>
                                <TextBlock Style="{StaticResource SubHint}"
                                           Text="Adjust this option if you've encountered any issues with pasting from clipboard or clipboard managers."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Pinned screenshots"/>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="PinnedRoundedCornersCheck" Content="Rounded corners" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="PinnedShadowCheck" Content="Shadow" Margin="0,0,12,0"/>
                                        <CheckBox x:Name="PinnedBorderCheck" Content="Border"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Keep history"/>
                                    <Slider x:Name="HistorySlider" Width="240" HorizontalAlignment="Left"
                                            Minimum="0" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="OnHistorySliderChanged"/>
                                </DockPanel>
                                <Grid Margin="162,0,0,0" Width="240" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Never" Foreground="{StaticResource TextDisabledBrush}" FontSize="10" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="1 day" Foreground="{StaticResource TextDisabledBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="3 days" Foreground="{StaticResource TextDisabledBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="1 week" Foreground="{StaticResource TextDisabledBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="1 month" Foreground="{StaticResource TextDisabledBrush}" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Style="{StaticResource SubHint}" Margin="162,6,0,0"
                                           Text="You can restore old files with &quot;Capture History&quot; option from the tray."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="All-In-One"/>
                                    <CheckBox x:Name="AllInOneRememberCheck" Content="Remember last selection"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Text recognition"/>
                                    <ComboBox x:Name="OcrLanguageCombo" Width="240" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Automatically Detect Language" Tag="auto"/>
                                        <ComboBoxItem Content="English" Tag="en"/>
                                        <ComboBoxItem Content="Spanish" Tag="es"/>
                                        <ComboBoxItem Content="French" Tag="fr"/>
                                        <ComboBoxItem Content="German" Tag="de"/>
                                        <ComboBoxItem Content="Italian" Tag="it"/>
                                        <ComboBoxItem Content="Portuguese" Tag="pt"/>
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text=""/>
                                    <StackPanel>
                                        <CheckBox x:Name="OcrJoinLinesCheck" Content="Keep line breaks"/>
                                        <CheckBox x:Name="OcrDetectLinksCheck" Content="Detect links" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Dialogs"/>
                                    <Button Content="Reset All Warning Dialogs" MinWidth="160"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource PillButtonSecondary}" Click="OnResetWarnings"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hidden: retention is now driven by the Keep-history slider above. -->
                        <TextBox x:Name="RetentionDaysBox" Visibility="Collapsed"/>
                        <TextBox x:Name="HistoryLimitBox" Visibility="Collapsed"/>
                        <TextBox x:Name="SelfTimerBox" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ===================== ABOUT ===================== -->
                <ScrollViewer x:Name="SectionAbout" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel Margin="4,8" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE722;" FontFamily="{StaticResource IconFont}"
                                           FontSize="44" HorizontalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="WinShot" FontSize="22" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="AboutVersionText" HorizontalAlignment="Center"
                                           Margin="0,2,0,0" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="A fast, lightweight screenshot &amp; recording tool for Windows."
                                           HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Version"/>
                                    <TextBlock x:Name="AboutVersionValue" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Runtime"/>
                                    <TextBlock x:Name="AboutRuntimeValue" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Windows"/>
                                    <TextBlock x:Name="AboutOsValue" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Install folder"/>
                                    <TextBlock x:Name="AboutInstallValue" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Updates"/>
                                    <Button x:Name="AboutCheckUpdatesButton" Content="Check for updates"
                                            MinWidth="160" HorizontalAlignment="Left"
                                            Style="{StaticResource PillButtonSecondary}" Click="OnAboutCheckUpdates"/>
                                </DockPanel>
                                <DockPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Project"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="GitHub repository" MinWidth="160"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PillButtonSecondary}" Click="OnAboutOpenRepo"/>
                                        <Button Content="Open logs folder" MinWidth="140" Margin="8,0,0,0"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PillButtonSecondary}" Click="OnAboutOpenLogs"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </DockPanel>
</Window>
