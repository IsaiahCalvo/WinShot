<Window x:Class="WinShot.SettingsUi.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinShot — Settings" Width="540" SizeToContent="Height"
        Background="#2B2B2B" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="185"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4DA3FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2D7DFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#2D7DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4DA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="#3A3A3A" BorderBrush="#555555"
                                                BorderThickness="1" CornerRadius="4">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,8,0" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#BBBBBB"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#454545"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="8,0,24,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#2F2F2F" BorderBrush="#555555" BorderThickness="1"
                                        CornerRadius="4" Margin="0,2,0,0" MaxHeight="220"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D7DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <StackPanel Margin="24,8,24,20">
        <TextBlock Style="{StaticResource SectionHeader}" Text="General" Margin="0,8,0,8"/>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Save folder"/>
            <Button DockPanel.Dock="Right" Content="Browse…" Style="{StaticResource ActionButton}" Click="OnBrowse"/>
            <TextBox x:Name="SaveFolderBox"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Image format"/>
            <ComboBox x:Name="FormatCombo" Width="90" HorizontalAlignment="Left" Style="{StaticResource DarkCombo}">
                <ComboBoxItem Content="png"/>
                <ComboBoxItem Content="jpg"/>
            </ComboBox>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Copy capture to clipboard"/>
            <CheckBox x:Name="AutoCopyCheck" Content="Automatically after every capture"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Overlay auto-close (seconds)"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="OverlayCloseBox" Width="70"/>
                <TextBlock Style="{StaticResource Hint}" Text="0 = stay until dismissed"/>
            </StackPanel>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="History limit"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="HistoryLimitBox" Width="70"/>
                <TextBlock Style="{StaticResource Hint}" Text="items kept"/>
            </StackPanel>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Launch at startup"/>
            <CheckBox x:Name="StartupCheck" Content="Start WinShot when I sign in"/>
        </DockPanel>

        <TextBlock Style="{StaticResource SectionHeader}" Text="Recording"/>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Recording frame rate"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="RecordingFpsBox" Width="70"/>
                <TextBlock Style="{StaticResource Hint}" Text="10–60 fps"/>
            </StackPanel>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="GIF frame rate"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="GifFpsBox" Width="70"/>
                <TextBlock Style="{StaticResource Hint}" Text="5–20 fps"/>
            </StackPanel>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Record audio"/>
            <CheckBox x:Name="RecordAudioCheck" Content="Capture microphone while recording"/>
        </DockPanel>

        <TextBlock Style="{StaticResource SectionHeader}" Text="Hotkeys"/>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Capture region / window"/>
            <TextBox x:Name="HotkeyRegionBox" Width="160" HorizontalAlignment="Left"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Capture fullscreen"/>
            <TextBox x:Name="HotkeyFullscreenBox" Width="160" HorizontalAlignment="Left"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Record screen"/>
            <TextBox x:Name="HotkeyRecordBox" Width="160" HorizontalAlignment="Left"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Capture text (OCR)"/>
            <TextBox x:Name="HotkeyOcrBox" Width="160" HorizontalAlignment="Left"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Scrolling capture"/>
            <TextBox x:Name="HotkeyScrollingBox" Width="160" HorizontalAlignment="Left"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" MinWidth="80" Style="{StaticResource ActionButton}" Click="OnCancel"/>
            <Button Content="Save" MinWidth="80" Style="{StaticResource AccentButton}" Click="OnSave"/>
        </StackPanel>
    </StackPanel>
</Window>
