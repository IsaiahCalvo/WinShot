<Application x:Class="WinShot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Single source of truth for the whole app. Merged here so every WPF
                     window gets the design system for free; ThemeResources.EnsureLoaded
                     remains as an idempotent guard for WinForms-first startup paths. -->
                <ResourceDictionary Source="pack://application:,,,/WinShot;component/Theme/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
