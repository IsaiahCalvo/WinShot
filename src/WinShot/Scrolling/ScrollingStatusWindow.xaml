<Window x:Class="WinShot.Scrolling.ScrollingStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" SizeToContent="WidthAndHeight" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False" WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="{StaticResource RadiusCard}" Background="{StaticResource FloatingBgBrush}"
            BorderBrush="{StaticResource TopHighlightBrush}" BorderThickness="1"
            Padding="14,10" Effect="{StaticResource FloatingShadow}">
        <StackPanel Orientation="Horizontal">
            <!-- Live preview of the growing stitched image (downscaled snapshot per iteration).
                 Hidden until the first snapshot arrives so the pill stays compact at start. -->
            <Border x:Name="PreviewHost" Width="46" Height="46" Margin="0,0,12,0"
                    CornerRadius="8" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    ClipToBounds="True" VerticalAlignment="Center">
                <Image x:Name="PreviewImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                               Margin="8,0,14,0" VerticalAlignment="Center"
                               Text="Scrolling capture — starting…"/>
                    <Button x:Name="BtnStop" Style="{StaticResource StopButton}" Content="Stop" Click="OnStop"/>
                </StackPanel>
                <!-- Indeterminate accent shimmer: a fallback progress cue that always animates,
                     even before the first preview snapshot or when previews are disabled. -->
                <Border Height="3" Margin="0,8,0,0" CornerRadius="1.5"
                        Background="{StaticResource SurfaceAltBrush}" ClipToBounds="True">
                    <Border x:Name="Shimmer" Width="60" Height="3" CornerRadius="1.5"
                            HorizontalAlignment="Left" Background="{StaticResource AccentBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ShimmerXform" X="-60"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
