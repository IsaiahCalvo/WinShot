<Window x:Class="WinShot.Recording.RecordingOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" SizeToContent="WidthAndHeight" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F4F4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2D7DFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4DA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Border CornerRadius="10" Background="#F22B2B2B" BorderBrush="#33FFFFFF" BorderThickness="1"
            Padding="18" MouseLeftButtonDown="OnDragMove">
        <StackPanel Width="230">
            <TextBlock Text="Record screen" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <RadioButton x:Name="Mp4Radio" Style="{StaticResource DarkRadio}" GroupName="Format"
                         Content="MP4 video" IsChecked="True"/>
            <RadioButton x:Name="GifRadio" Style="{StaticResource DarkRadio}" GroupName="Format"
                         Content="GIF animation"/>
            <CheckBox x:Name="AudioCheck" Content="Record audio (microphone)" Foreground="White" FontSize="12"
                      Margin="0,4,0,0" Cursor="Hand"
                      IsEnabled="{Binding IsChecked, ElementName=Mp4Radio}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource ActionButton}" Content="Cancel" Click="OnCancel"/>
                <Button Style="{StaticResource AccentButton}" Content="Start" Click="OnStart" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
