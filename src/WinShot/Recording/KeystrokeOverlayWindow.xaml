<Window x:Class="WinShot.Recording.KeystrokeOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        WindowStartupLocation="Manual" IsHitTestVisible="False">
    <Grid>
        <Border x:Name="Pill" CornerRadius="17" Background="#E61E1E1E" BorderBrush="#33FFFFFF" BorderThickness="1"
                Padding="16,7" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,14" Opacity="0">
            <TextBlock x:Name="KeysText" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
