<Window x:Class="WinShot.Recording.RecordingCountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="170" Height="170" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        ShowInTaskbar="False" WindowStartupLocation="Manual">
    <Border CornerRadius="85" Background="#F22B2B2B" BorderBrush="#2D7DFF" BorderThickness="3">
        <Grid>
            <TextBlock x:Name="CountText" Text="3" Foreground="White" FontSize="84" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Esc to cancel" Foreground="#888888" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
        </Grid>
    </Border>
</Window>
